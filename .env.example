# ─────────────────────────────────────────────
# Agent Testing Framework — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider API Key ─────────────────────
# Required — used by both the agent and the LLM judge
GROQ_API_KEY=your-groq-api-key-here

# ── Agent Configuration ──────────────────────
AGENT_PROVIDER=groq
AGENT_MODEL=llama-3.3-70b-versatile

# ── Judge Configuration ──────────────────────
JUDGE_PROVIDER=groq
JUDGE_MODEL=llama-3.3-70b-versatile
